local SAVE_FILE = "InfiniteDrillSimulator_Settings.json"

local function saveSettings()
    local data = {
        toggleKey = State and State.toggleKey and State.toggleKey.Name or "RightControl",
        mineDelay = State and State.mineDelay or 0,
        clickDelay = State and State.clickDelay or 0.05,
        autoClaimEnabled = State and State.autoClaimEnabled or true,
        teleportToClick = State and State.teleportToClick or true,
        useVipPump = State and State.useVipPump or false,
        selectedZone = State and State.selectedZone or nil,
        selectedMine = State and State.selectedMine or nil,
    }
    pcall(function()
        writefile(SAVE_FILE, game:GetService("HttpService"):JSONEncode(data))
    end)
end

local function loadSettings()
    local ok, content = pcall(function()
        return readfile(SAVE_FILE)
    end)
    if ok and content and content ~= "" then
        local ok2, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(content)
        end)
        if ok2 and data then return data end
    end
    return {}
end

