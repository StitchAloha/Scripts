local function detectPlayerZoneAndMine()
    local playerPos = getPlayerPosition()
    if not playerPos then return nil, nil end

    local zonesFolder = workspace:FindFirstChild("Zones")
    if not zonesFolder then return nil, nil end

    local candidates = {}
    for _, zone in pairs(zonesFolder:GetChildren()) do
        local minesFolder = zone:FindFirstChild("Mines")
        if minesFolder then
            for _, mine in pairs(minesFolder:GetChildren()) do
                local blockModels = mine:FindFirstChild("BlockModels")
                if blockModels then
                    local minDist = math.huge
                    for _, p in pairs(blockModels:GetDescendants()) do
                        if p:IsA("BasePart") then
                            local dist = (playerPos - p.Position).Magnitude
                            if dist < minDist then minDist = dist end
                        end
                    end
                    if minDist < math.huge then
                        table.insert(candidates, { zone = zone.Name, mine = mine.Name, dist = minDist })
                    end
                end
            end
        end
    end

    table.sort(candidates, function(a, b) return a.dist < b.dist end)
    if #candidates > 0 then return candidates[1].zone, candidates[1].mine end
    return nil, nil
end

