	AUTO_FARMING = not AUTO_FARMING
	if AUTO_FARMING then task.spawn(autoFarmLoop) else setLog("Stopping...") end
	updateBindTexts()
end)

--// КЛАВИШИ
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if not input.KeyCode or input.KeyCode == Enum.KeyCode.Unknown then return end

	if bindListening then
		BINDS[bindListening] = input.KeyCode
		local b = bindButtons[bindListening]
		if b then b.BackgroundColor3 = Color3.fromRGB(48, 48, 65) end
		setLog("'" .. bindListening .. "' → [" .. input.KeyCode.Name .. "]")
		bindListening = nil
		updateBindTexts()
		return
	end

	if input.KeyCode == BINDS.AutoFarm then
		AUTO_FARMING = not AUTO_FARMING
		if AUTO_FARMING then task.spawn(autoFarmLoop) else setLog("Stopping...") end
		updateBindTexts()
		return
	end

	if AUTO_FARMING then return end

	if input.KeyCode == BINDS.Collect then
		task.spawn(doCollectAndHome)
	elseif input.KeyCode == BINDS.Home then
		doHome()
	elseif input.KeyCode == BINDS.Split then
		task.spawn(doSplit)
	elseif input.KeyCode == BINDS.SellAll then
		doSell()
	end
end)

