--// СБОР ЛУТА — ТОЛЬКО СВОЙ ПЛОТ + В РАДИУСЕ 800
local function getMatchingLoot()
	local matches = {}
	local ch = player.Character
	if not ch then return matches end
	local hrp = ch:FindFirstChild("HumanoidRootPart")
	if not hrp then return matches end

	for _, m in ipairs(lootFolder:GetChildren()) do
		if m:IsA("Model") and m:GetAttribute("PlotName") == CURRENT_PLOT then
			local ok, pv = pcall(function() return m:GetPivot() end)
			if ok then
				local dist = (pv.Position - hrp.Position).Magnitude
				if dist <= 800 then
					table.insert(matches, m)
				end
			end
		end
	end
	return matches
end

--// HOME = SafeZone (сдача ресурсов), невысоко
local function doHome()
	local sz = getSafeZone()
	if not sz then
		setLog("SafeZone not found!")
		return false
	end
	waitChar()
	local targetCF = CFrame.new(sz.Position.X, sz.Position.Y + sz.Size.Y / 2 + 1, sz.Position.Z)
	safeTp(targetCF)
	task.wait(0.1)
	freezeCharacter()
	setLog("Home (SafeZone).")
	return true
end

--// COLLECT — свой плот, радиус 800
local function doCollect()
	if busy then return false end
	busy = true
	setLog("Collecting...")
	waitChar()

	local loot = getMatchingLoot()
	if #loot == 0 then
		setLog("No loot found.")
		busy = false
		return false
	end

	setLog("Found " .. #loot .. " items...")
	for i, m in ipairs(loot) do
		if not m or not m.Parent then continue end
		local ok, pv = pcall(function() return m:GetPivot() end)
		if ok then
			safeTp(pv + Vector3.new(0, 1, 0))
		end
		task.wait(TELEPORT_DELAY)
		if i % 15 == 0 then setLog("Collecting " .. i .. "/" .. #loot) end
	end

	-- Второй проход
	task.wait(0.3)
	local remaining = getMatchingLoot()
	if #remaining > 0 then
		setLog("Picking up " .. #remaining .. " remaining...")
		for _, m in ipairs(remaining) do
			if not m or not m.Parent then continue end
			local ok, pv = pcall(function() return m:GetPivot() end)
			if ok then
				safeTp(pv + Vector3.new(0, 1, 0))
			end
			task.wait(TELEPORT_DELAY)
		end
	end

	setLog("Collected all.")
	busy = false
	return true
end

local function doCollectAndHome()
	doCollect()
	task.wait(0.2)
	doHome()
end

