--// SPLIT
local function doSplit()
	setLog("Splitting...")
	local sz = getSplitZone()
	if not sz then setLog("SplitZone not found!") return false end
	waitChar()

	local targetCF = CFrame.new(sz.Position.X, sz.Position.Y + sz.Size.Y / 2 + 1, sz.Position.Z)
	safeTp(targetCF)
	task.wait(0.3)
	freezeCharacter()
	task.wait(0.2)

	if not hasHeldItem() then
		if not doEquipStick() then
			setLog("Cannot equip stick!")
			return false
		end
	end

	safeTp(targetCF)
	task.wait(0.15)
	freezeCharacter()

	local ok = pcall(function()
		ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SplitRequest"):FireServer(1, true)
	end)
	setLog(ok and "Split done!" or "Split error!")
	return ok
end

--// АВТОФАРМ
-- Home (сдать) → SplitZone → Split → Ждём лут → Collect → Home (сдать) → Sell → повтор
local function autoFarmLoop()
	if AUTO_LOOP_RUNNING then return end
	AUTO_LOOP_RUNNING = true
	setLog("Auto Farm STARTED!")
	autoFarmBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 50)
	updateBindTexts()

	while AUTO_FARMING do
		pcall(detectPlayerPlot)
		updateStatus()
		pcall(function()
			islandDropdown.Text = CURRENT_ISLAND or "?"
			plotDropdown.Text = CURRENT_PLOT or "?"
		end)

		-- 1) Home — сдать что есть
		setLog("[Auto] Home (deliver)...")
		doHome()
		task.wait(0.5)
		if not AUTO_FARMING then break end

		-- 2) Split (с ретраями)
		local splitOk = false
		for attempt = 1, MAX_SPLIT_RETRIES do
			if not AUTO_FARMING then break end
			setLog("[Auto] Split attempt " .. attempt .. "/" .. MAX_SPLIT_RETRIES)
			splitOk = doSplit()
			if splitOk then break end
			task.wait(0.5)
		end
		if not AUTO_FARMING then break end

		-- 3) Ждём лут
		setLog("[Auto] Waiting for loot...")
		local waitTime = 0
		local lootFound = false
		while waitTime < SPLIT_WAIT_TIME and AUTO_FARMING do
			local loot = getMatchingLoot()
			if #loot > 0 then
				setLog("[Auto] Loot: " .. #loot .. " items!")
				lootFound = true
				task.wait(0.6)
				break
			end
			task.wait(0.3)
			waitTime = waitTime + 0.3
		end
		if not AUTO_FARMING then break end

		-- Если лута нет — повтор сплита
		if not lootFound then
			setLog("[Auto] No loot, retrying...")
			continue
		end

		-- 4) Collect
		setLog("[Auto] Collecting...")
		doCollect()
		task.wait(0.3)
		if not AUTO_FARMING then break end

		-- 5) Home — сдать собранное
		setLog("[Auto] Home (deliver)...")
		doHome()
		task.wait(0.5)
		if not AUTO_FARMING then break end

		-- 6) Sell
		setLog("[Auto] Selling...")
		doSell()
		task.wait(0.3)
		if not AUTO_FARMING then break end

		-- 7) Проверка остатков
		local leftover = getMatchingLoot()
		if #leftover > 0 then
			setLog("[Auto] Leftover: " .. #leftover .. ", collecting...")
			doCollect()
			task.wait(0.2)
			doHome()
			task.wait(0.3)
			doSell()
			task.wait(0.2)
		end
		if not AUTO_FARMING then break end

		setLog("[Auto] Cycle done!")
		task.wait(0.2)
	end

	setLog("Auto Farm STOPPED.")
	autoFarmBtn.BackgroundColor3 = Color3.fromRGB(80, 20, 20)
	AUTO_LOOP_RUNNING = false
	updateBindTexts()
end

