local function createDropdown(parent, position, options, default, callback)
	local container = Instance.new("Frame", parent)
	container.Position = position
	container.Size = UDim2.new(0, 225, 0, 20)
	container.BackgroundColor3 = Color3.fromRGB(38, 38, 52)
	container.ZIndex = 2
	container.BorderSizePixel = 0
	Instance.new("UICorner", container).CornerRadius = UDim.new(0, 5)

	local button = Instance.new("TextButton", container)
	button.Size = UDim2.new(1, 0, 1, 0)
	button.Text = default or options[1]
	button.TextColor3 = Color3.new(1, 1, 1)
	button.BackgroundTransparency = 1
	button.ZIndex = 3
	button.Font = Enum.Font.Gotham
	button.TextSize = 10

	local listFrame = Instance.new("ScrollingFrame", container)
	listFrame.Position = UDim2.new(0, 0, 1, 2)
	listFrame.Size = UDim2.new(1, 0, 0, math.min(#options * 20, 100))
	listFrame.CanvasSize = UDim2.new(0, 0, 0, #options * 20)
	listFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 42)
	listFrame.Visible = false
	listFrame.ZIndex = 10
	listFrame.BorderSizePixel = 0
	listFrame.ScrollBarThickness = 3
	Instance.new("UICorner", listFrame).CornerRadius = UDim.new(0, 5)

	for i, option in ipairs(options) do
		local opt = Instance.new("TextButton", listFrame)
		opt.Size = UDim2.new(1, 0, 0, 20)
		opt.Position = UDim2.new(0, 0, 0, (i - 1) * 20)
		opt.Text = option
		opt.BackgroundTransparency = 0.6
		opt.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
		opt.TextColor3 = Color3.new(1, 1, 1)
		opt.ZIndex = 11
		opt.Font = Enum.Font.Gotham
		opt.TextSize = 10
		opt.BorderSizePixel = 0
		opt.MouseButton1Click:Connect(function()
			button.Text = option
			listFrame.Visible = false
			callback(option)
		end)
	end
	button.MouseButton1Click:Connect(function()
		listFrame.Visible = not listFrame.Visible
	end)
	return button
end

